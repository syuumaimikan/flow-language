{
  "id": "com.flow.loader.lua",
  "name": "Lua_Load",
  "version": "1.0.0",
  "enabled": true,
  "description": "JSON stdin/stdout ABIでLuaスクリプトを実行するローダー例",
  "nodes": [
    {
      "languageType": "loader.lua.execute",
      "title": "Lua Execute",
      "category": "ローダー/Lua",
      "inputs": [
        {
          "id": "payload",
          "label": "Payload",
          "dataType": "object",
          "required": true
        }
      ],
      "outputs": [
        {
          "id": "result",
          "label": "Result",
          "dataType": "object"
        }
      ],
      "defaultProperties": {},
      "runtime": {
        "kind": "external-process",
        "command": "lua",
        "args": [
          "plugins/loaders/lua_test.lua"
        ]
      }
    }
  ]
}

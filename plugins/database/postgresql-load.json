{
  "id": "com.flow.database.postgresql",
  "name": "PostgreSQL_Load",
  "version": "1.0.0",
  "description": "JSON stdin/stdout ABIを使うPostgreSQL外部アダプターの前提プラグイン",
  "enabled": true,
  "nodes": [
    {
      "languageType": "database.postgresql.query",
      "title": "PostgreSQL Query",
      "category": "プラグイン/データベース",
      "description": "接続情報、SQL、パラメーターを外部PostgreSQLアダプターへ渡します。",
      "inputs": [
        {
          "id": "connection",
          "label": "Connection",
          "dataType": "object",
          "required": true
        },
        {
          "id": "sql",
          "label": "SQL",
          "dataType": "string",
          "required": true
        },
        {
          "id": "params",
          "label": "Params",
          "dataType": "array",
          "required": false
        }
      ],
      "outputs": [
        {
          "id": "rows",
          "label": "Rows",
          "dataType": "array"
        }
      ],
      "defaultProperties": {},
      "runtime": {
        "kind": "external-process",
        "command": "plugins/database/postgresql_adapter.exe",
        "args": []
      }
    }
  ]
}

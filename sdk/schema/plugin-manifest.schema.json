{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Flow Language Plugin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "nodes"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "languageType",
          "title",
          "category",
          "inputs",
          "outputs",
          "defaultProperties"
        ],
        "properties": {
          "languageType": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "inputs": {
            "type": "array"
          },
          "outputs": {
            "type": "array"
          },
          "defaultProperties": {
            "type": "object"
          },
          "runtime": {
            "type": "object"
          },
          "expression": {
            "type": "string"
          }
        }
      }
    }
  }
}
